# StreamFlow — Variáveis de ambiente
# Copie este arquivo para .env e ajuste conforme necessário.
# O docker-compose.yml já define valores padrão para todos os serviços.

# Portas dos serviços (apenas para referência — definidas no compose)
GATEWAY_PORT=8080
AUTH_PORT=3001
CATALOG_PORT=3002
STREAMING_PORT=3003
RECOMMENDATION_PORT=3004
NOTIFICATION_PORT=3005
BILLING_PORT=3006
ANALYTICS_PORT=3007
